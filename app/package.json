{
  "name": "sysndd",
  "version": "0.21.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "dev:docker": "vite --mode docker",
    "build:docker": "vite build --mode docker",
    "build:production": "vite build --mode production",
    "seo:generate:fixture": "node scripts/generate-seo-pages.mjs --fixture scripts/fixtures/seo --out dist --base-url https://sysndd.dbmr.unibe.ch",
    "seo:generate": "node scripts/generate-seo-pages.mjs --out dist",
    "seo:verify": "node scripts/verify-seo-build.mjs dist",
    "build:seo": "npm run build:production && npm run seo:generate:fixture",
    "type-check": "vue-tsc --noEmit",
    "type-check:strict": "node scripts/type-check-strict.js",
    "lint": "eslint . --ext .vue,.js,.ts,.tsx",
    "lint:fix": "eslint . --ext .vue,.js,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,css,scss}\"",
    "prepare": "husky",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:codegen": "playwright codegen http://localhost:5173",
    "docs:screenshots": "playwright test --config=playwright.docs-screenshots.config.ts"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@unhead/vue": "^3.1.3",
    "@upsetjs/bundle": "^1.11.0",
    "@vee-validate/rules": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootstrap-vue-next": "^0.45.5",
    "chart.js": "^4.5.1",
    "cytoscape": "^3.34.0",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-svg": "^0.4.0",
    "d3": "^7.4.2",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.8",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "gsap": "^3.15.0",
    "html2canvas": "^1.4.1",
    "markdown-it": "^14.2.0",
    "ngl": "^2.4.0",
    "pinia": "^3.0.4",
    "splitpanes": "^4.1.2",
    "swagger-ui": "^5.32.6",
    "swagger-ui-dist": "^5.32.6",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.35",
    "vue-chartjs": "^5.3.3",
    "vue-dompurify-html": "^5.3.0",
    "vue-router": "^5.1.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/cytoscape": "^3.31.0",
    "@types/d3": "^7.4.3",
    "@types/dompurify": "^3.2.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.0.18",
    "@vue/compiler-sfc": "^3.5.35",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.0",
    "axios": "^1.17.0",
    "cssnano": "^8.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.3.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.4",
    "workbox-window": "^7.4.1"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "js-cookie": "3.0.7",
    "qs": "6.15.2",
    "uuid": "11.1.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix --max-warnings=50",
      "prettier --write"
    ],
    "*.{js}": [
      "eslint --fix --max-warnings=50",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  }
}
