# =============================================================================
# SysNDD Environment Configuration Template
# =============================================================================
#
# Purpose: Template for required environment variables
#
# Setup:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env with your values
#   3. Start services: docker compose up
#
# WARNING: Never commit .env to version control (contains secrets)
#          Ensure .env is listed in .gitignore
#
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# MySQL/MariaDB settings for the sysndd database

MYSQL_DATABASE=sysndd_db
MYSQL_USER=your_username_here
MYSQL_PASSWORD=your_secure_password_here
MYSQL_ROOT_PASSWORD=your_secure_root_password_here

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Plumber API authentication and settings

PASSWORD=your_api_password_here
SMTP_PASSWORD=your_smtp_password_here
API_CONFIG=sysndd_db

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
# Environment mode: development, production

ENVIRONMENT=development

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS (Cross-Origin Resource Sharing)
# Required for production to allow browser requests from your domain
# Include protocol (https://) - do NOT include trailing slash
#
# Examples:
#   Single origin:    CORS_ALLOWED_ORIGINS=https://sysndd.dbmr.unibe.ch
#   Multiple origins: CORS_ALLOWED_ORIGINS=https://sysndd.dbmr.unibe.ch,https://staging.sysndd.dbmr.unibe.ch
#
# Note: localhost origins are always allowed for development
# Firefox requires strict CORS configuration - see issue #143

CORS_ALLOWED_ORIGINS=https://your-production-domain.com

# -----------------------------------------------------------------------------
# SEO Prerender Configuration
# -----------------------------------------------------------------------------
# Optional frontend build-time generation of crawlable public route HTML.

SEO_GENERATE=false
SEO_API_BASE_URL=http://api:7777/api
SEO_PUBLIC_BASE_URL=https://sysndd.dbmr.unibe.ch

# -----------------------------------------------------------------------------
# LLM Configuration (Phase 58+)
# -----------------------------------------------------------------------------
# Gemini API for cluster summaries
# Get your key at: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# OMIM Configuration
# -----------------------------------------------------------------------------
# OMIM download key for authenticated access to genemap2.txt
# Required for: OMIM ontology updates, disease comparisons
# Get your key at: https://www.omim.org/downloads/
# After registration, use the key from your download URLs

OMIM_DOWNLOAD_KEY=your_omim_download_key_here

# -----------------------------------------------------------------------------
# Log Cleanup (scheduled DB retention) — issue #105
# -----------------------------------------------------------------------------
# The `log-cleanup` service prunes old rows from the operational request log
# table (`logging`) on a daily schedule. It reuses the API image and connects
# via the same RMariaDB pool/config as the API. Override these to tune it.
#
#   LOG_RETENTION_DAYS    Delete `logging` rows older than this many days (default 30)
#   LOG_CLEANUP_AT        Daily run time, HH:MM in container (UTC) time (default 03:00)
#   LOG_CLEANUP_DRY_RUN   When 1/true/yes/on: count-only, never delete (default false)

LOG_RETENTION_DAYS=30
LOG_CLEANUP_AT=03:00
LOG_CLEANUP_DRY_RUN=false

# -----------------------------------------------------------------------------
# Optional Settings
# -----------------------------------------------------------------------------
# Docker Compose project name (affects container naming)

COMPOSE_PROJECT_NAME=sysndd

# =============================================================================
# Security Notes
# =============================================================================
#
# - Use strong passwords (16+ characters, mixed case, numbers, symbols)
# - Rotate passwords regularly in production environments
# - Keep .env file permissions restricted (chmod 600 .env)
# - Never share .env contents in logs, error messages, or documentation
# - Verify .env is in .gitignore before committing any changes
#
# =============================================================================
