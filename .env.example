# =============================================================================
# SysNDD Environment Configuration Template
# =============================================================================
#
# Purpose: Template for required environment variables
#
# Setup:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env with your values
#   3. Start services: docker compose up
#
# WARNING: Never commit .env to version control (contains secrets)
#          Ensure .env is listed in .gitignore
#
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# MySQL/MariaDB settings for the sysndd database

MYSQL_DATABASE=sysndd_db
MYSQL_USER=your_username_here
MYSQL_PASSWORD=your_secure_password_here
MYSQL_ROOT_PASSWORD=your_secure_root_password_here

# Database version surface (issue #22). Optional, set at release time.
# DB_VERSION is the semantic version (major.minor.patch) of the DB schema +
# seed data; DB_COMMIT is the last db/-folder git short hash. The migration
# seeds a baseline; when these are set the API refreshes the db_version row at
# startup so the App and /api/version report the deployed values. Capture them
# on a host with the repo checked out: ./db/scripts/update-db-version.sh >> .env
# Current schema version is 0.26.0 (ships migration 036 — disease cross-ontology mappings).
# DB_VERSION=0.26.0
# DB_COMMIT=unknown

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Plumber API authentication and settings

PASSWORD=your_api_password_here
SMTP_PASSWORD=your_smtp_password_here
API_CONFIG=sysndd_db

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
# Environment mode: development, production

ENVIRONMENT=development

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS (Cross-Origin Resource Sharing)
# Required for production to allow browser requests from your domain
# Include protocol (https://) - do NOT include trailing slash
#
# Examples:
#   Single origin:    CORS_ALLOWED_ORIGINS=https://sysndd.dbmr.unibe.ch
#   Multiple origins: CORS_ALLOWED_ORIGINS=https://sysndd.dbmr.unibe.ch,https://staging.sysndd.dbmr.unibe.ch
#
# Note: localhost origins are always allowed for development
# Firefox requires strict CORS configuration - see issue #143

CORS_ALLOWED_ORIGINS=https://your-production-domain.com

# -----------------------------------------------------------------------------
# Public authentication admission throttle (#550)
# -----------------------------------------------------------------------------
# POST /api/auth/signup, /api/auth/authenticate, and
# /api/user/password/reset/request allow this many attempts per client in one
# window. Invalid values safely fall back to their defaults; there is no disable
# switch. State is bounded at AUTH_ENDPOINT_MAX_TRACKED active fingerprints.
AUTH_ENDPOINT_PER_CALLER_MAX=5
AUTH_ENDPOINT_WINDOW_SECONDS=60
AUTH_ENDPOINT_MAX_TRACKED=20000
# Empty for the shipped direct-Traefik edge. Set ONLY an actual front-proxy CIDR
# when one is deployed before Traefik; the limiter takes the rightmost untrusted
# X-Forwarded-For hop. See documentation/09-deployment.qmd.
AUTH_ENDPOINT_TRUSTED_PROXY_CIDRS=

# -----------------------------------------------------------------------------
# SEO Prerender Configuration
# -----------------------------------------------------------------------------
# Optional frontend build-time generation of crawlable public route HTML.

SEO_GENERATE=false
SEO_API_BASE_URL=http://api:7777/api
SEO_PUBLIC_BASE_URL=https://sysndd.dbmr.unibe.ch

# -----------------------------------------------------------------------------
# LLM Configuration (Phase 58+)
# -----------------------------------------------------------------------------
# Gemini API for cluster summaries
# Get your key at: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# NCBI E-utilities (PubMed) Configuration
# -----------------------------------------------------------------------------
# An NCBI API key raises the per-IP EUtils rate limit from the anonymous 3 req/s
# to 10 req/s. Without it, the publication-date backfill (#494) 429s large EFetch
# batches into a whole-job "systemic outage" and writes nothing. Strongly
# recommended for the worker (the pubtator cron shares the same NCBI IP budget).
# Get a key: https://www.ncbi.nlm.nih.gov/account/ -> Settings -> API Key Management
# Optional: NCBI_EUTILS_EMAIL is added as the EUtils `email` contact param.
NCBI_API_KEY=
NCBI_EUTILS_EMAIL=

# -----------------------------------------------------------------------------
# OMIM Configuration
# -----------------------------------------------------------------------------
# OMIM download key for authenticated access to genemap2.txt
# Required for: OMIM ontology updates, disease comparisons
# Get your key at: https://www.omim.org/downloads/
# After registration, use the key from your download URLs

OMIM_DOWNLOAD_KEY=your_omim_download_key_here

# -----------------------------------------------------------------------------
# Log Cleanup (scheduled DB retention) — issue #105
# -----------------------------------------------------------------------------
# The `log-cleanup` service prunes old rows from the operational request log
# table (`logging`) on a daily schedule. It reuses the API image and connects
# via the same RMariaDB pool/config as the API. Override these to tune it.
#
#   LOG_RETENTION_DAYS    Delete `logging` rows older than this many days (default 30)
#   LOG_CLEANUP_AT        Daily run time, HH:MM in container (UTC) time (default 04:00,
#                         staggered off the 03:00 database backup)
#   LOG_CLEANUP_DRY_RUN   When 1/true/yes/on: count-only, never delete (default false)
#
# The same daily loop also prunes terminal, non-retryable `async_jobs` rows
# (status completed/failed/cancelled AND active_request_hash IS NULL) — #535 S7:
#   ASYNC_JOB_RETENTION_DAYS           Delete terminal jobs older than this (default 90)
#   ASYNC_JOB_RETENTION_DRY_RUN        Count-only; unrecognized value fails safe (default false)
#   ASYNC_JOB_RETENTION_BATCH_SIZE     Candidate PKs read+deleted per batch, clamped <=1000 (default 1000)
#   ASYNC_JOB_RETENTION_LOCK_WAIT_SECONDS  Per-batch row+metadata lock wait, clamped <=30 (default 10)

LOG_RETENTION_DAYS=30
LOG_CLEANUP_AT=04:00
LOG_CLEANUP_DRY_RUN=false
ASYNC_JOB_RETENTION_DAYS=90
ASYNC_JOB_RETENTION_DRY_RUN=false
ASYNC_JOB_RETENTION_BATCH_SIZE=1000
ASYNC_JOB_RETENTION_LOCK_WAIT_SECONDS=10

# -----------------------------------------------------------------------------
# Optional Settings
# -----------------------------------------------------------------------------
# Docker Compose project name (affects container naming)

COMPOSE_PROJECT_NAME=sysndd

# =============================================================================
# Security Notes
# =============================================================================
#
# - Use strong passwords (16+ characters, mixed case, numbers, symbols)
# - Rotate passwords regularly in production environments
# - Keep .env file permissions restricted (chmod 600 .env)
# - Never share .env contents in logs, error messages, or documentation
# - Verify .env is in .gitignore before committing any changes
#
# =============================================================================
