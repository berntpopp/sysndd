##
## SysNDD API — config.yml template (Phase B B4 — CI-safe dummy values)
##
## Copy this file to `api/config.yml` and fill in real credentials BEFORE
## running the stack against a real database. The real `api/config.yml` is
## gitignored (`.gitignore` has `config.yml` under `api/`) so you never
## accidentally commit secrets.
##
## The API image must not bake real api/config.yml into image layers. This
## template is used only to create a runtime api/config.yml for local/CI stacks
## when no operator-specific file exists.
##
## NOTHING in this file should contain a real credential. The MySQL
## password here is the same as `MYSQL_PASSWORD` in `.env.example` and is a
## well-known placeholder; a real deployment replaces it with a rotated
## secret from the ops vault. See `.env.example` for the matching env vars
## and `.planning/_archive/legacy-plans/v11.0/phase-b.md` §3 Phase B.B4 for the CI smoke-test
## rationale.
##
## Mirrors the structure of the real `config.yml` (sysndd_db,
## sysndd_db_local, sysndd_db_test, sysndd_db_dev environments) so
## `config::get("sysndd_db")` always returns a list of the correct shape.

default:
  sysndd_db:
    workdir: "/app"
    dbtype: mysql
    dbname: sysndd_db
    user: "your_username_here"
    password: "your_secure_password_here"
    salt: "ci_dummy_salt_must_be_replaced_in_production"
    server: "0.0.0.0"
    host: "mysql"
    port: "3306"
    port_self: "7777"
    # 64-char dummy JWT signing secret. Replace with a high-entropy secret
    # from the ops vault in any environment that processes real logins.
    secret: "ci_dummy_jwt_secret_replace_me_with_64_random_chars_xxxxxxxxxxxx"
    refresh: 3600
    token_expiry: 3600
    base_url: "http://localhost"
    api_base_url: "http://localhost/api"
    gemini_model: "gemini-3.5-flash"
    mail_noreply_user: "noreply@example.com"
    mail_noreply_host: "mailpit"
    mail_noreply_port: 1025
    mail_noreply_use_ssl: FALSE
    mail_noreply_overwrite: TRUE
    mail_noreply_password: ""
    omim_token: "ci_dummy_omim_token"
    nddscore_zenodo_record_id: "20258027"
    nddscore_zenodo_api_base_url: "https://zenodo.org/api/records"

  sysndd_db_local:
    workdir: "/app"
    dbtype: mysql
    dbname: sysndd_db
    user: "your_username_here"
    password: "your_secure_password_here"
    salt: "ci_dummy_salt_must_be_replaced_in_production"
    server: "0.0.0.0"
    host: "127.0.0.1"
    port: "7654"
    port_self: "7778"
    secret: "ci_dummy_jwt_secret_replace_me_with_64_random_chars_xxxxxxxxxxxx"
    refresh: 3600
    token_expiry: 3600
    base_url: "http://127.0.0.1"
    api_base_url: "http://127.0.0.1:7778"
    gemini_model: "gemini-3.5-flash"
    mail_noreply_user: "noreply@example.com"
    mail_noreply_host: "127.0.0.1"
    mail_noreply_port: 1025
    mail_noreply_use_ssl: FALSE
    mail_noreply_overwrite: TRUE
    mail_noreply_password: ""
    omim_token: "ci_dummy_omim_token"
    nddscore_zenodo_record_id: "20258027"
    nddscore_zenodo_api_base_url: "https://zenodo.org/api/records"

  sysndd_db_test:
    workdir: "/app"
    dbtype: mysql
    dbname: sysndd_db_test
    user: "your_username_here"
    password: "your_secure_password_here"
    salt: "ci_dummy_salt_must_be_replaced_in_production"
    server: "0.0.0.0"
    host: "127.0.0.1"
    port: "7655"
    port_self: "7779"
    secret: "ci_dummy_jwt_secret_replace_me_with_64_random_chars_xxxxxxxxxxxx"
    refresh: 3600
    token_expiry: 3600
    base_url: "http://127.0.0.1"
    api_base_url: "http://127.0.0.1:7779"
    gemini_model: "gemini-3.5-flash"
    mail_noreply_user: "noreply@example.com"
    mail_noreply_host: "127.0.0.1"
    mail_noreply_port: 1025
    mail_noreply_use_ssl: FALSE
    mail_noreply_overwrite: TRUE
    mail_noreply_password: ""
    omim_token: "ci_dummy_omim_token"
    nddscore_zenodo_record_id: "20258027"
    nddscore_zenodo_api_base_url: "https://zenodo.org/api/records"

  sysndd_db_dev:
    workdir: "/app"
    dbtype: mysql
    dbname: sysndd_db
    user: "your_username_here"
    password: "your_secure_password_here"
    salt: "ci_dummy_salt_must_be_replaced_in_production"
    server: "0.0.0.0"
    host: "mysql"
    port: "3306"
    port_self: "7777"
    secret: "ci_dummy_jwt_secret_replace_me_with_64_random_chars_xxxxxxxxxxxx"
    refresh: 3600
    token_expiry: 3600
    base_url: "http://localhost"
    api_base_url: "http://localhost:7777"
    gemini_model: "gemini-3.5-flash"
    mail_noreply_user: "noreply@example.com"
    mail_noreply_host: "mailpit"
    mail_noreply_port: 1025
    mail_noreply_use_ssl: FALSE
    mail_noreply_overwrite: TRUE
    mail_noreply_password: ""
